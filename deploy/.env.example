# Deployment Layer configuration template.
#
# Copy to /opt/deployment/.env on the application server and fill in real
# values. Never commit a populated .env. Values already present in the
# environment (e.g. exported by the CD workflow) take precedence over this file.

# --- Deployment location --------------------------------------------------
# Persistent directory on the server that holds docker-compose.yml, this .env,
# and rollback state. This is NOT the runner workspace.
DEPLOY_DIR=/opt/deployment

# --- Compose / service ----------------------------------------------------
COMPOSE_PROJECT_NAME=app
APP_SERVICE=app

# --- Application runtime ---------------------------------------------------
APP_PORT=3000
APP_CPU_LIMIT=1
APP_MEM_LIMIT=512M
# APP_IMAGE is injected at deploy time by the Deployment Layer — do not set it here.

# --- Health check ----------------------------------------------------------
HEALTHCHECK_URL=http://localhost:3000/health
HEALTHCHECK_RETRIES=10
HEALTHCHECK_INTERVAL=5

# --- Supply-chain verification (cosign, keyless) ---------------------------
# COSIGN_VERIFY=false disables verification — for local smoke tests ONLY.
COSIGN_VERIFY=true
# Regex matching the OIDC certificate identity of the signing workflow, e.g.
#   ^https://github.com/<owner>/<repo>/.github/workflows/.+@.+$
COSIGN_CERT_IDENTITY_REGEXP=
COSIGN_CERT_OIDC_ISSUER=https://token.actions.githubusercontent.com

# --- Registry (GHCR) -------------------------------------------------------
REGISTRY=ghcr.io
# Leave blank if the Docker daemon on the server is already logged in.
GHCR_USERNAME=
GHCR_TOKEN=

# --- Cleanup ---------------------------------------------------------------
PRUNE_AFTER_DEPLOY=true
